# ─────────────────────────────────────────────
# Server configuration
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────
# LLM / AI provider configuration
# ─────────────────────────────────────────────
LLM_PROVIDER=grok              # options: claude | openai | gemini | grok
ANTHROPIC_API_KEY=sk-your-anthropic-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=sk-your-gemini-api-key-here
GROK_API_KEY=your-grok-api-key-here

# ─────────────────────────────────────────────
# Rayna Tours API (for fetching tours)
# ─────────────────────────────────────────────
RAYNA_API_BASE_URL=https://earnest-panda-e8edbd.netlify.app/api

# ─────────────────────────────────────────────
# Session configuration
# ─────────────────────────────────────────────
SESSION_MAX_MESSAGES=10        # number of messages to keep in context
SESSION_TTL_MINUTES=30         # session time-to-live in minutes

# ─────────────────────────────────────────────
# Rate limiting configuration
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000     # 1 minute window
RATE_LIMIT_MAX_REQUESTS=20     # max requests per window per IP